#!/usr/bin/env python3
import sys
import argparse
from src.logic.agent_manager import manager

def main():
    parser = argparse.ArgumentParser(description="SHADOW_GRIMORIO CLI - Control del Enjambre")
    subparsers = parser.add_subparsers(dest="command")

    # Comando: shadow status
    subparsers.add_parser("status", help="Muestra el estado de los agentes")
    
    # Comando: shadow kill
    subparsers.add_parser("kill", help="Aniquila todos los agentes en segundo plano")

    # Comando: shadow start
    subparsers.add_parser("start", help="Lanza la interfaz visual (TUI)")

    args = parser.parse_args()

    if args.command == "status":
        print("\n--- ESTADO DEL ENJAMBRE ---")
        for name, status in manager.listar_agentes().items():
            color = "\033[92m" if status == "on" else "\033[91m"
            print(f"[{color}{status.upper()}\033[0m] Agente: {name}")
    
    elif args.command == "kill":
        manager.matar_todo()
    
    elif args.command == "start":
        from src.tui.app import ShadowGrimorio
        app = ShadowGrimorio()
        app.run()
    
    else:
        parser.print_help()

if __name__ == "__main__":
    main()

